    "framer-motion": "^11.11.17",
    "ioredis": "^5.4.1",
    "lucide-react": "^1.12.0",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
