# Database
DATABASE_URL="postgresql://user:pass@localhost:5432/songdaq?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Solana
NEXT_PUBLIC_SOLANA_NETWORK="devnet"
NEXT_PUBLIC_SOLANA_RPC="https://api.devnet.solana.com"
SOLANA_PAYER_SECRET=""  # optional admin fallback only; normal artist launches are wallet-paid
JUPITER_API_KEY=""      # optional; lite public Jupiter API works for many routes
JUPITER_API_BASE=""     # optional override, defaults to Jupiter swap v1

# Audius / Open Audio Protocol
NEXT_PUBLIC_AUDIUS_APP_NAME="songdaq"
NEXT_PUBLIC_AUDIUS_API_KEY=""
AUDIUS_DISCOVERY_HOST=""  # optional pinned host, otherwise auto-discovered

# WalletConnect
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""

# Protocol
APP_MODE="paper" # paper | devnet | live
TREASURY_WALLET="" # treasury/reserve wallet for launch liquidity inventory
NEXT_PUBLIC_TREASURY_WALLET="" # optional display-only copy of the treasury wallet
TREASURY_ROYALTY_RECEIVING_WALLET=""
TREASURY_ROYALTY_POOL_WALLET=""
TREASURY_BUYBACK_WALLET=""
TREASURY_LIQUIDITY_WALLET=""
TREASURY_PROTOCOL_RESERVE_WALLET=""
TREASURY_HOLDER_REWARDS_WALLET=""
NEXT_PUBLIC_ROYALTY_SETUP_EMAIL="admin@song-daq.com"
NEXT_PUBLIC_SUPPORT_EMAIL="admin@song-daq.com"

# MVP feature flags
ENABLE_ROYALTY_REQUESTS="true"
ENABLE_ADMIN_DASHBOARD="true"
ENABLE_MANUAL_ROYALTY_RECORDING="true"
ENABLE_ROYALTY_ENGINE="true"
ENABLE_ROYALTY_POOL_CONTRIBUTIONS="true"
ENABLE_PAPER_MODE="true"
ENABLE_AUTOMATED_BUYBACKS="false"
ENABLE_AUTOMATED_LIQUIDITY="false"
ENABLE_HOLDER_REWARDS="false"
ENABLE_CLAIMABLE_REWARDS="false"

# Admin
# Comma-separated Solana wallet addresses allowed to open /admin and run moderation actions.
# This is server-only. Do not expose it as NEXT_PUBLIC_*.
ADMIN_WALLETS=""
ADMIN_USERNAME="admin"
ADMIN_PASSWORD=""
ADMIN_SESSION_SECRET=""
ADMIN_AUDIUS_NAMES="Darnell Williams"
ADMIN_AUDIUS_HANDLES=""
ADMIN_AUDIUS_USER_IDS=""
